---
// StatusBar.astro

interface Props {
  page?: 'home' | 'about' | 'writing' | 'tools' | 'post';
}

const { page = 'home' } = Astro.props;

const sectionMaps: Record<string, Record<string, string>> = {
  home: {
    'hero-section':          'HOME',
    'manifesto-section':     'MANIFESTO',
    'features-section':      'PROJECTS',
    'transmissions-section': 'WRITING',
    'footer-section':        'FOOTER',
  },
  about: {
    'manifesto-section': 'ABOUT',
    'footer-section':    'FOOTER',
  },
  writing: {
    'transmissions-section': 'WRITING',
    'footer-section':        'FOOTER',
  },
  tools: {
    'footer-section': 'FOOTER',
  },
  post: {
    'footer-section': 'FOOTER',
  },
};

const initialLabel: Record<string, string> = {
  home:    'HOME',
  about:   'ABOUT',
  writing: 'WRITING',
  tools:   'TOOLS',
  post:    'READING',
};

const mapJson = JSON.stringify(sectionMaps[page]);
const initial = initialLabel[page];
---

<aside
  id="status-bar"
  data-section-map={mapJson}
  data-initial-label={initial}
  class="fixed bottom-0 left-0 right-0 z-50 bg-[var(--color-carbon)]/90 backdrop-blur-md border-t border-[var(--color-wire)]"
>
  <div class="max-w-6xl mx-auto px-6 py-2 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="status-dot w-2 h-2 rounded-full bg-[var(--color-signal)]"></span>
      <span id="current-section" class="font-mono text-xs text-[var(--color-ash)]">{initial}</span>
    </div>

    <div class="flex items-center gap-4">
      <div class="hidden md:block w-32 h-1 bg-[var(--color-plate)] rounded-full overflow-hidden">
        <div id="scroll-progress" class="h-full bg-[var(--color-signal)] transition-all duration-100" style="width: 0%"></div>
      </div>
      <span id="scroll-percent" class="font-mono text-xs text-[var(--color-ash)]">0%</span>
    </div>
  </div>
</aside>

<script>
  function initStatusBar() {
    const bar = document.getElementById('status-bar');
    if (!bar) return;

    const sectionMap: Record<string, string> = JSON.parse(bar.dataset.sectionMap || '{}');
    const initialLbl = bar.dataset.initialLabel || '';

    const currentSectionEl = document.getElementById('current-section');
    const scrollProgressEl = document.getElementById('scroll-progress');
    const scrollPercentEl  = document.getElementById('scroll-percent');

    if (currentSectionEl) currentSectionEl.textContent = initialLbl;

    // --- Scroll progress ---
    function onScroll() {
      const scrollTop    = window.scrollY;
      const docHeight    = document.documentElement.scrollHeight - window.innerHeight;
      const progress     = docHeight > 0 ? Math.round((scrollTop / docHeight) * 100) : 0;
      if (scrollProgressEl) scrollProgressEl.style.width = `${progress}%`;
      if (scrollPercentEl)  scrollPercentEl.textContent  = `${progress}%`;
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // --- Section detection via scroll position math (no flicker) ---
    const sectionIds = Object.keys(sectionMap);
    const sectionEls = sectionIds
      .map(id => ({ id, label: sectionMap[id], el: document.getElementById(id) }))
      .filter(s => s.el);

    let ticking = false;

    function updateSection() {
      const scrollY = window.scrollY + window.innerHeight * 0.35;
      let current = initialLbl;

      for (const section of sectionEls) {
        const top = section.el.offsetTop;
        if (scrollY >= top) {
          current = section.label;
        }
      }

      if (currentSectionEl && currentSectionEl.textContent !== current) {
        currentSectionEl.textContent = current;
      }

      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateSection);
        ticking = true;
      }
    }, { passive: true });

    updateSection();
  }

  initStatusBar();
  document.addEventListener('astro:page-load', initStatusBar);
</script>
