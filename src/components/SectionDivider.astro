---
interface Props {
  code: string;
  title: string;
  colour?: 'signal' | 'copper' | 'cyan';
}

const { code, title, colour = 'signal' } = Astro.props;
---

<section class="section-divider py-2 px-6 relative overflow-hidden" data-section={code} data-colour={colour}>
  <div class="sweep-line"></div>
</section>

<style>
  .section-divider {
    background: transparent;
    border-top: none;
    border-bottom: none;
  }

  .sweep-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--sweep-colour) 50%, transparent 100%);
    transform: scaleX(0);
    transform-origin: left;
    opacity: 0.6;
  }

  [data-colour="signal"] { --sweep-colour: var(--color-signal); }
  [data-colour="copper"] { --sweep-colour: var(--color-copper); }
  [data-colour="cyan"]   { --sweep-colour: var(--color-cyan); }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initDividers() {
    const dividers = document.querySelectorAll('.section-divider');

    dividers.forEach(divider => {
      const sweep = divider.querySelector('.sweep-line') as HTMLElement;

      if (sweep) {
        let lastScrollY = window.scrollY;

        ScrollTrigger.create({
          trigger: divider,
          start: 'top 85%',
          end: 'bottom 15%',
          onUpdate: (self) => {
            const scrollY = window.scrollY;
            const direction = scrollY > lastScrollY ? 'down' : 'up';
            lastScrollY = scrollY;

            const progress = self.progress;

            if (direction === 'down') {
              gsap.to(sweep, {
                scaleX: progress,
                duration: 0.3,
                ease: 'power2.out',
                overwrite: 'auto'
              });
            } else {
              gsap.to(sweep, {
                scaleX: progress,
                duration: 0.3,
                ease: 'power2.out',
                overwrite: 'auto'
              });
            }
          }
        });
      }
    });
  }

  initDividers();
  document.addEventListener('astro:page-load', initDividers);
</script>
