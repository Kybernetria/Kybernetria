---
// IcosahedronCanvas.astro
---

<div id="icosahedron-container" class="absolute inset-0 pointer-events-none" style="z-index: 10; overflow: visible;">
  <canvas id="icosahedron-canvas" class="absolute inset-0 block w-full h-full" style="overflow: visible;" width="0" height="0"></canvas>
</div>

<script>
  import * as THREE from 'three';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);
  ScrollTrigger.config({ ignoreMobileResize: true });

  let activeCanvas = null;
  let cleanupCurrent = () => {};

  function init() {
    const container = document.getElementById('icosahedron-container');
    const canvas = document.getElementById('icosahedron-canvas');

    if (!(container instanceof HTMLDivElement) || !(canvas instanceof HTMLCanvasElement)) return;
    if (activeCanvas === canvas) return;

    cleanupCurrent();
    activeCanvas = canvas;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.z = 8;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const isMobile = window.innerWidth < 768;
    const radius = isMobile ? 1.5 : 2.4;

    const geometry = new THREE.IcosahedronGeometry(radius, 0);
    const edges = new THREE.EdgesGeometry(geometry);
    const material = new THREE.LineBasicMaterial({
      color: 0x7EC8C8,
      transparent: true,
      opacity: 0.85
    });
    const icosahedron = new THREE.LineSegments(edges, material);

    const outerGeometry = new THREE.IcosahedronGeometry(radius * 1.18, 0);
    const outerEdges = new THREE.EdgesGeometry(outerGeometry);
    const outerMaterial = new THREE.LineBasicMaterial({
      color: 0x7EC8C8,
      transparent: true,
      opacity: 0.12
    });
    const outerShell = new THREE.LineSegments(outerEdges, outerMaterial);

    const positions = geometry.attributes.position;
    const uniqueVerts = [];
    const seen = new Set();
    for (let i = 0; i < positions.count; i++) {
      const key = `${positions.getX(i).toFixed(3)},${positions.getY(i).toFixed(3)},${positions.getZ(i).toFixed(3)}`;
      if (!seen.has(key)) {
        seen.add(key);
        uniqueVerts.push(positions.getX(i), positions.getY(i), positions.getZ(i));
      }
    }

    const pointsGeometry = new THREE.BufferGeometry();
    pointsGeometry.setAttribute('position', new THREE.Float32BufferAttribute(uniqueVerts, 3));
    const pointsMaterial = new THREE.PointsMaterial({
      color: 0xd93f2e,
      size: 0.08,
      transparent: true,
      opacity: 0.9,
      sizeAttenuation: true
    });
    const vertexPoints = new THREE.Points(pointsGeometry, pointsMaterial);

    const group = new THREE.Group();
    group.add(icosahedron);
    group.add(outerShell);
    group.add(vertexPoints);
    scene.add(group);

    let mouseX = 0;
    let mouseY = 0;
    let animationId = 0;

    const syncSceneSize = () => {
      const { width, height } = container.getBoundingClientRect();
      if (!width || !height) return;

      camera.aspect = width / height;
      camera.updateProjectionMatrix();
      renderer.setSize(width, height, false);

      const mobileView = width < 768;
      camera.position.x = mobileView ? 0 : -3;
      camera.position.y = mobileView ? -1.5 : 0;
    };

    const onMouseMove = (event) => {
      const rect = container.getBoundingClientRect();
      mouseX = event.clientX - (rect.left + rect.width / 2);
      mouseY = event.clientY - (rect.top + rect.height / 2);
    };

    document.addEventListener('mousemove', onMouseMove);

    const resizeObserver = new ResizeObserver(() => {
      syncSceneSize();
      ScrollTrigger.refresh();
    });
    resizeObserver.observe(container);

    const onResize = () => {
      syncSceneSize();
    };
    window.addEventListener('resize', onResize);

    syncSceneSize();

    const clock = new THREE.Clock();
    const animate = () => {
      animationId = requestAnimationFrame(animate);
      const delta = clock.getDelta();

      icosahedron.rotation.x += 0.03 * delta;
      icosahedron.rotation.y += 0.05 * delta;
      icosahedron.rotation.z += 0.015 * delta;

      const targetX = mouseX * 0.0005;
      const targetY = mouseY * 0.0005;

      group.rotation.y += (targetX - group.rotation.y) * 0.05;
      group.rotation.x += (targetY - group.rotation.x) * 0.05;

      renderer.render(scene, camera);
    };
    animate();

    const scrollCtx = gsap.context(() => {
      gsap.to(container, {
        scrollTrigger: {
          trigger: '#hero-section',
          start: 'top top',
          end: () => `+=${container.getBoundingClientRect().height || 1}`,
          scrub: true,
          invalidateOnRefresh: true,
        },
        scale: 0.7,
        opacity: 0.3,
        ease: 'none'
      });
    }, container);

    cleanupCurrent = () => {
      if (activeCanvas !== canvas) return;

      cancelAnimationFrame(animationId);
      resizeObserver.disconnect();
      window.removeEventListener('resize', onResize);
      document.removeEventListener('mousemove', onMouseMove);
      scrollCtx.revert();
      renderer.dispose();
      geometry.dispose();
      edges.dispose();
      material.dispose();
      outerGeometry.dispose();
      outerEdges.dispose();
      outerMaterial.dispose();
      pointsGeometry.dispose();
      pointsMaterial.dispose();
      activeCanvas = null;
      cleanupCurrent = () => {};
    };

    document.addEventListener('astro:before-swap', cleanupCurrent, { once: true });
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
