---
import { getCollection } from 'astro:content';
import SectionDivider from './SectionDivider.astro';
import { Github } from 'lucide-astro';

const base = '/';

const toolsEntries = await getCollection('tools');
const tools = toolsEntries
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3)
  .map(entry => ({
    name: entry.data.name,
    description: entry.data.description,
    github: entry.data.github,
    tags: entry.data.tags,
    status: entry.data.status
  }));
---

<SectionDivider code="S2" title="PROJECTS" colour="cyan" />

<section id="features-section" class="w-full bg-carbon py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12 border-b border-wire pb-4">
      <h2 class="font-subhead text-2xl uppercase tracking-widest text-chalk">Projects</h2>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">

      {tools.map((tool) => (
        <div class="feature-card h-full">
          <a href={tool.github} target="_blank" rel="noopener noreferrer" class="group flex flex-col bg-plate border-l-2 border-l-cyan/30 border-t border-r border-b border-wire/40 rounded-xl transition-all duration-200 hover:-translate-y-1 hover:scale-[1.02] hover:border-l-cyan hover:border-wire cursor-pointer h-full">
            <div class="p-8 flex-1">
              <div class="mb-6 flex items-center justify-between">
                <div class="p-2 bg-carbon rounded-lg border border-wire group-hover:border-signal/30 transition-colors">
                  <Github class="text-signal" size={24} />
                </div>
                <span class={`font-mono text-xs uppercase px-2 py-1 rounded ${
                  tool.status === 'active' ? 'bg-cyan/20 text-cyan' :
                  tool.status === 'stable' ? 'bg-signal/20 text-signal' :
                  'bg-copper/20 text-copper'
                }`}>
                  {tool.status}
                </span>
              </div>
              <h3 class="font-headline text-2xl text-copper/90 tracking-wide mb-4 group-hover:text-copper transition-colors duration-200">{tool.name}</h3>
              <p class="font-body text-ash text-sm leading-relaxed mb-4">
                {tool.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {tool.tags.map((tag) => (
                  <span class="font-mono text-xs text-ash/70 bg-carbon/50 px-2 py-1 rounded border border-wire/50">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div class="px-8 py-4 border-t border-wire/40 flex items-center group-hover:border-cyan/30 transition-colors duration-200">
              <span class="font-subhead uppercase text-sm text-ash/70 group-hover:text-cyan transition-colors duration-200">
                View Repository <span class="inline-block transform group-hover:translate-x-1 transition-transform duration-200">→</span>
              </span>
            </div>
          </a>
        </div>
      ))}

    </div>

    <div class="mt-12 text-center">
      <a href={`${base}tools/`} class="inline-flex items-center gap-2 font-subhead uppercase text-sm text-ash hover:text-signal transition-colors">
        View All Projects <span>→</span>
      </a>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initFeatures() {
    const ctx = gsap.context(() => {
      const cards = gsap.utils.toArray('.feature-card');

      if (cards.length > 0) {
        gsap.fromTo(cards,
          { y: 30, opacity: 0 },
          {
            scrollTrigger: {
              trigger: "#features-section",
              start: "top 80%",
              toggleActions: "play none none none"
            },
            y: 0,
            opacity: 1,
            duration: 0.6,
            stagger: 0.12,
            ease: "power2.out"
          }
        );
      }
    }, "#features-section");

    document.addEventListener("astro:before-swap", () => {
      ctx.revert();
    }, { once: true });
  }

  initFeatures();
  document.addEventListener("astro:page-load", initFeatures);
</script>
