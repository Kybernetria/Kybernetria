---
const base = '/';
---

<footer id="footer-section" class="w-full bg-[#0A0A0A] text-ash rounded-t-2xl pt-12 px-6 md:px-12 border-t border-wire relative z-10">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">

      <div class="flex flex-col">
        <h3 class="font-headline text-2xl tracking-widest text-chalk mb-3">KYBERNETRIA</h3>
        <p class="font-body text-sm max-w-xs text-ash/80">
          Architectures of liberation through systems thinking and collective intelligence.
        </p>
      </div>

      <div class="flex flex-col gap-3">
        <h4 class="font-mono text-xs tracking-widest uppercase mb-1">Navigate</h4>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          <a href={`${base}blog/`} class="font-subhead text-sm tracking-wide hover:text-signal transition-colors">Writing</a>
          <a href={`${base}about/`} class="font-subhead text-sm tracking-wide hover:text-signal transition-colors">About</a>
          <a href={`${base}tools/`} class="font-subhead text-sm tracking-wide hover:text-signal transition-colors">Tools</a>
          <a href={`${base}rss.xml`} class="font-subhead text-sm tracking-wide hover:text-signal transition-colors">RSS</a>
        </div>
      </div>
    </div>

    <div class="border-t border-wire py-4 flex flex-col md:flex-row items-center justify-between gap-3">
      <div class="font-mono text-[0.7rem] tracking-wider">
        © KYBERNETRIA — CC BY-SA 4.0
      </div>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-cyan animate-pulse shadow-[0_0_8px_var(--color-cyan)]"></div>
        <span class="font-mono text-xs tracking-widest text-cyan">SYSTEMS NOMINAL</span>
      </div>
    </div>
  </div>
</footer>
