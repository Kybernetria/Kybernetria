---
import { getCollection } from 'astro:content';
import SectionDivider from './SectionDivider.astro';
interface Props {
  limit?: number;
  showHeading?: boolean;
  showDivider?: boolean;
}

const { limit, showHeading = true, showDivider = true } = Astro.props;
const base = '/';

let posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

posts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
if (limit) {
  posts = posts.slice(0, limit);
}
---

{showDivider && <SectionDivider code="S3" title="WRITING" />}

<section id="transmissions-section" class="w-full py-24 px-6 md:px-12" style="background: linear-gradient(to bottom, var(--color-carbon) 0%, var(--color-forge) 15%, var(--color-forge) 70%, var(--color-carbon) 100%);">
  <div class="max-w-7xl mx-auto">

    {showHeading && (
      <div class="mb-12 border-b border-wire pb-4">
        <h2 class="font-subhead text-2xl uppercase tracking-widest text-chalk">Recent Writing</h2>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article class="group relative bg-plate border-l-2 border-l-signal/30 border-t border-r border-b border-wire/40 rounded-xl hover:border-l-signal hover:border-wire hover:bg-plate/80 transition-all duration-300 overflow-hidden">
          {post.data.heroImage && (
            <a href={`${base}writing/${post.id.replace(/\.md$/, '')}/`} class="block">
              <div class="w-full aspect-video overflow-hidden">
                <img src={post.data.heroImage} alt="" class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" />
              </div>
            </a>
          )}
          <div class="p-6 md:p-8">
            <time datetime={post.data.date.toISOString()} class="block font-mono text-xs text-copper/60 tracking-widest mb-4">
              {post.data.date.toISOString().split('T')[0]}
            </time>
            <a href={`${base}writing/${post.id.replace(/\.md$/, '')}/`} class="block group">
              <h3 class="font-subhead text-[1.3rem] font-semibold text-chalk group-hover:text-signal transition-colors duration-200 mb-3 leading-tight tracking-tight">
                {post.data.title}
              </h3>
            </a>
            <p class="font-body text-[0.875rem] text-ash line-clamp-3 mb-4">
              {post.data.excerpt}
            </p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {post.data.tags.map((tag) => (
                <a href={`${base}writing/tag/${tag.toLowerCase()}/`} class="font-mono text-[0.65rem] uppercase px-2 py-0.5 border border-wire/40 rounded text-ash/60 hover:border-signal hover:text-signal transition-colors">
                  {tag}
                </a>
              ))}
            </div>
            <a href={`${base}writing/${post.id.replace(/\.md$/, '')}/`} class="inline-flex items-center font-subhead uppercase text-sm text-signal opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 tracking-widest">
              Read →
            </a>
          </div>
        </article>
      ))}
    </div>

    {showHeading && (
      <div class="mt-12 text-center">
        <a href={`${base}writing/`} class="inline-flex items-center gap-2 font-subhead uppercase text-sm text-ash hover:text-signal transition-colors">
          View All Writing <span>→</span>
        </a>
      </div>
    )}
  </div>
</section>
