---
import IcosahedronCanvas from './IcosahedronCanvas.astro';
const base = '/';
---

<header class="relative w-full h-[100svh] md:h-[100dvh] bg-carbon overflow-visible flex" id="hero-section">
  <!-- Radial bg gradient -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,var(--color-forge)_0%,transparent_60%)] opacity-50 pointer-events-none"></div>

  <!-- Icosahedron Canvas Container -->
  <div class="absolute inset-0 md:left-[60%] md:w-[40%] w-full h-full z-0 opacity-30 md:opacity-100 transition-opacity duration-500">
    <IcosahedronCanvas />
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full md:w-[60%] h-full flex flex-col justify-end pb-24 px-6 md:pl-12 md:pr-12">

    <div class="hero-eyebrow font-mono text-xs text-ash tracking-[0.2em] uppercase mb-6 opacity-0 translate-y-5">
      SYSTEMS THINKING FOR THE COMMONS. <!-- PLACEHOLDER -->
    </div>

    <!-- Headline separated into words for stagger -->
    <h1 class="font-headline text-chalk leading-[0.95] mb-6 drop-shadow-sm flex flex-wrap" style="font-size: clamp(4rem, 12vw, 8rem); padding-bottom: 0.1em;">
      <span class="clip-reveal inline-block"><span class="hero-word inline-block opacity-0 translate-y-16">KYBERNETRIA</span></span>
    </h1>

    <p class="hero-subhead font-body italic text-ash text-xl md:text-2xl max-w-lg mb-10 leading-relaxed">
      A journal of cybernetics, <br class="md:hidden"/>
      collective intelligence, and the architectures of liberation.
    </p>


    <div class="hero-cta flex flex-wrap gap-6 items-center opacity-0 translate-y-5 font-subhead uppercase tracking-wide">
      <a href={`${base}blog/`} class="text-signal hover:text-copper transition-colors duration-200 flex items-center gap-2 group">
        Read the Journal
        <span class="transform group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>

  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-ash text-sm animate-pulse z-10 pointer-events-none">
    ↓
  </div>
</header>

<script>
  import gsap from 'gsap';

  function initHero() {
    const ctx = gsap.context(() => {
      const tl = gsap.timeline();

      tl.to('.hero-eyebrow', {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power3.out"
      }, "+=0.1")
      .to('.hero-word', {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.04,
        ease: "power3.out"
      }, "-=0.6")
      .to('.hero-subhead', {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power3.out"
      }, "-=0.2")
      .to('.hero-cta', {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power3.out"
      }, "-=0.55");
    }, "#hero-section");

    document.addEventListener("astro:before-swap", () => {
      ctx.revert();
    }, { once: true });
  }

  initHero();
  document.addEventListener("astro:page-load", initHero);
</script>
