---
// Manifesto.astro
---

<section id="manifesto-section" class="relative w-full overflow-hidden bg-carbon py-16 md:py-20">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,var(--color-forge)_0%,transparent_55%)] opacity-30"></div>

  <div class="mx-auto max-w-7xl px-6 md:px-12 relative">
    <div class="mb-6 lg:hidden">
      <a href="/about/" class="font-subhead text-[1.05rem] leading-none text-cyan tracking-wide uppercase hover:text-signal transition-colors">
        Manifesto
      </a>
    </div>

    <a
      href="/about/"
      class="hidden lg:block absolute left-0 top-1 text-cyan font-subhead text-[1.05rem] leading-none tracking-wide uppercase hover:text-signal transition-colors [writing-mode:vertical-rl] rotate-180 -translate-x-[calc(100%+0.75rem)]"
    >
      Manifesto
    </a>

    <div class="max-w-5xl">
      <p class="font-body text-ash text-lg md:text-xl lg:text-2xl leading-snug md:leading-tight max-w-3xl mb-8 md:mb-10 text-balance">
        <span class="m-word inline-block opacity-0 translate-y-3">Complex</span>
        <span class="m-word inline-block opacity-0 translate-y-3">systems</span>
        <span class="m-word inline-block opacity-0 translate-y-3">are</span>
        <span class="m-word inline-block opacity-0 translate-y-3">not</span>
        <span class="m-word inline-block opacity-0 translate-y-3">machines</span>
        <span class="m-word inline-block opacity-0 translate-y-3">to</span>
        <span class="m-word inline-block opacity-0 translate-y-3">optimize.</span>
        <span class="m-word inline-block opacity-0 translate-y-3 text-chalk/90">They are</span>
      </p>

      <div class="mb-8 md:mb-10">
        <span class="m-word m-final-word block opacity-0 translate-y-3 text-signal font-headline text-[clamp(1.4rem,3.2vw,4rem)] tracking-[0.05em] leading-[0.92] text-left whitespace-normal lg:whitespace-nowrap">
          LIVING, CIRCULAR, ENTANGLED TERRITORY.
        </span>
      </div>

      <p class="font-body text-ash text-lg md:text-xl lg:text-2xl max-w-3xl leading-snug md:leading-tight m-followup opacity-0 translate-y-3 text-balance">
        Kybernetria maps that territory — designing the protocols and politics that free us.
      </p>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initManifesto() {
    const ctx = gsap.context(() => {
      const words = gsap.utils.toArray('#manifesto-section .m-word');

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#manifesto-section',
          start: 'top 80%',
          toggleActions: 'play none none none'
        }
      });

      if (words.length > 0) {
        tl.to(words, {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.05,
          ease: 'power2.out'
        });
      }

      tl.to('#manifesto-section .m-followup', {
        y: 0,
        opacity: 1,
        duration: 0.6,
        ease: 'power2.out'
      }, '-=0.3');
    }, '#manifesto-section');

    document.addEventListener('astro:before-swap', () => {
      ctx.revert();
    }, { once: true });
  }

  initManifesto();
  document.addEventListener('astro:page-load', initManifesto);
</script>
