---
// Manifesto.astro
interface Props {
  standalone?: boolean;
}
const { standalone = false } = Astro.props;
---

<section id="manifesto-section" class="relative w-full overflow-hidden bg-carbon pt-24 md:pt-24 pb-32 md:pb-40 px-6 md:px-12">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0%,var(--color-forge)_0%,transparent_55%)] opacity-30"></div>

  <div class="mx-auto max-w-7xl relative">
    <div class="mb-12 md:mb-14">
      <a href="/about/" class="inline-block font-subhead text-2xl uppercase tracking-widest text-chalk hover:text-copper transition-colors">
        Manifesto
      </a>
    </div>

    <p class="font-body italic text-ash text-lg md:text-xl lg:text-2xl leading-[1.25] max-w-4xl mb-12 md:mb-14 text-balance">
      <span class="m-word inline-block opacity-0 translate-y-3">Complex</span>
      <span class="m-word inline-block opacity-0 translate-y-3">systems</span>
      <span class="m-word inline-block opacity-0 translate-y-3">are</span>
      <span class="m-word inline-block opacity-0 translate-y-3">not</span>
      <span class="m-word inline-block opacity-0 translate-y-3">machines</span>
      <span class="m-word inline-block opacity-0 translate-y-3">to</span>
      <span class="m-word inline-block opacity-0 translate-y-3">optimize.</span>
        <span class="m-word inline-block opacity-0 translate-y-3 text-copper">They are:</span>
    </p>

    <div class="mb-12 md:mb-14">
      <span class="m-word m-final-word block opacity-0 translate-y-3 text-signal font-headline text-[clamp(1.8rem,4vw,4.8rem)] tracking-[0.05em] leading-[0.92] text-left whitespace-normal lg:whitespace-nowrap">
        LIVING, CIRCULAR, ENTANGLED TERRITORY.
      </span>
    </div>

    <p class="font-body italic text-ash text-lg md:text-xl lg:text-2xl max-w-4xl leading-[1.25] m-followup opacity-0 translate-y-3 text-balance">
      Kybernetria maps that territory — designing the protocols and politics that free us.
    </p>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initManifesto() {
    const ctx = gsap.context(() => {
      const words = gsap.utils.toArray('#manifesto-section .m-word');

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#manifesto-section',
          start: 'top 80%',
          toggleActions: 'play none none none'
        }
      });

      if (words.length > 0) {
        tl.to(words, {
          y: 0,
          opacity: 1,
          duration: 0.5,
          stagger: 0.05,
          ease: 'power2.out'
        });
      }

      tl.to('#manifesto-section .m-followup', {
        y: 0,
        opacity: 1,
        duration: 0.6,
        ease: 'power2.out'
      }, '-=0.3');
    }, '#manifesto-section');

    document.addEventListener('astro:before-swap', () => {
      ctx.revert();
    }, { once: true });
  }

  initManifesto();
  document.addEventListener('astro:page-load', initManifesto);
</script>
