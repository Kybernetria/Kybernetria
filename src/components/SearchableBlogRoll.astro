---
import { getCollection } from 'astro:content';
import SectionDivider from './SectionDivider.astro';

interface Props {
  showHeading?: boolean;
  showDivider?: boolean;
}

const { showHeading = true, showDivider = true } = Astro.props;

let posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

posts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

{showDivider && <SectionDivider code="S3" title="WRITING" />}

<section id="transmissions-section" class="w-full py-24 px-6 md:px-12" style="background: linear-gradient(to bottom, var(--color-carbon) 0%, var(--color-forge) 15%, var(--color-forge) 70%, var(--color-carbon) 100%);">
  <div class="max-w-7xl mx-auto">

    {showHeading && (
      <div class="flex items-center justify-between mb-12 border-b border-wire pb-4">
        <h2 class="font-subhead text-2xl uppercase tracking-widest text-chalk">Recent Writing</h2>
        <a href="/writing/" class="font-mono text-sm text-signal hover:text-copper transition-colors">View All →</a>
      </div>
    )}

    <div class="mb-8 max-w-md">
      <div class="relative">
        <input 
          type="text" 
          id="post-search" 
          placeholder="Search articles..."
          class="w-full bg-plate border border-wire rounded-lg px-4 py-2 pl-10 font-mono text-sm text-chalk placeholder-ash/50 focus:border-signal focus:outline-none transition-colors"
        />
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ash/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </div>

    <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article 
          data-title={post.data.title.toLowerCase()}
          data-excerpt={post.data.excerpt.toLowerCase()}
          data-tags={post.data.tags.join(',').toLowerCase()}
          class="group relative bg-plate border-l-2 border-l-signal/30 border-t border-r border-b border-wire/40 rounded-xl hover:border-l-signal hover:border-wire hover:bg-plate/80 transition-all duration-300 overflow-hidden">
          {post.data.heroImage && (
            <a href={`/writing/${post.id.replace(/\.md$/, '')}/`} class="block">
              <div class="w-full aspect-video overflow-hidden">
                <img src={post.data.heroImage} alt="" class="w-full h-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" />
              </div>
            </a>
          )}
          <div class="p-6 md:p-8">
            <time datetime={post.data.date.toISOString()} class="block font-mono text-xs text-copper/60 tracking-widest mb-4">
              {post.data.date.toISOString().split('T')[0]}
            </time>
            <a href={`/writing/${post.id.replace(/\.md$/, '')}/`} class="block group">
              <h3 class="font-subhead text-[1.3rem] font-semibold text-chalk group-hover:text-signal transition-colors duration-200 mb-3 leading-tight tracking-tight">
                {post.data.title}
              </h3>
            </a>
            <p class="font-body text-[0.875rem] text-ash line-clamp-3 mb-4">
              {post.data.excerpt}
            </p>
            <div class="flex flex-wrap gap-1.5 mb-4">
              {post.data.tags.map((tag) => (
                <a href={`/writing/tag/${tag.toLowerCase()}/`} class="font-mono text-[0.65rem] uppercase px-2 py-0.5 border border-wire/40 rounded text-ash/60 hover:border-signal hover:text-signal transition-colors">
                  {tag}
                </a>
              ))}
            </div>
            <a href={`/writing/${post.id.replace(/\.md$/, '')}/`} class="inline-flex items-center font-subhead uppercase text-sm text-signal opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 tracking-widest">
              Read →
            </a>
          </div>
        </article>
      ))}
    </div>

    <p id="no-results" class="hidden text-center font-body text-ash py-12">No articles match your search.</p>
  </div>
</section>

<script>
  const searchInput = document.getElementById('post-search') as HTMLInputElement;
  const postsGrid = document.getElementById('posts-grid');
  const noResults = document.getElementById('no-results');

  function filterPosts() {
    if (!postsGrid || !noResults) return;
    
    const searchTerm = searchInput?.value.toLowerCase() || '';
    const posts = postsGrid.querySelectorAll('article');
    let visibleCount = 0;

    posts.forEach((post) => {
      const title = post.getAttribute('data-title') || '';
      const excerpt = post.getAttribute('data-excerpt') || '';
      const tags = post.getAttribute('data-tags') || '';
      
      const matches = title.includes(searchTerm) || excerpt.includes(searchTerm) || tags.includes(searchTerm);
      
      if (matches) {
        (post as HTMLElement).style.display = '';
        visibleCount++;
      } else {
        (post as HTMLElement).style.display = 'none';
      }
    });

    noResults.classList.toggle('hidden', visibleCount > 0);
  }

  searchInput?.addEventListener('input', filterPosts);
</script>