---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Github, ExternalLink } from 'lucide-astro';
import { getCollection } from 'astro:content';

const base = '/';

const toolsEntries = await getCollection('tools');
const tools = toolsEntries
  .sort((a, b) => a.data.order - b.data.order)
  .map(entry => ({
    name: entry.data.name,
    description: entry.data.description,
    github: entry.data.github,
    tags: entry.data.tags,
    status: entry.data.status
  }));
---

<BaseLayout title="Projects | Kybernetria">
  <Navbar />

  <main class="pt-32 min-h-[80vh]">
    <div class="max-w-7xl mx-auto px-6 md:px-12 mb-16">
      <div class="mb-4">
        <h1 class="font-headline text-5xl md:text-7xl text-chalk leading-[0.9] tracking-wide">
          PROJECTS
        </h1>
      </div>
      <p class="font-body text-ash text-lg max-w-2xl leading-relaxed">
        Open-source instruments for systems thinking, collective coordination, and the engineering of emancipatory architectures.
      </p>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => (
          <a
            href={tool.github}
            target="_blank"
            rel="noopener noreferrer"
            class="feature-card group flex flex-col bg-plate border-l-2 border-l-cyan/30 border-t border-r border-b border-wire/40 rounded-xl transition-all duration-200 hover:-translate-y-1 hover:scale-[1.02] hover:border-l-cyan hover:border-wire cursor-pointer h-full"
          >
            <div class="p-8 flex-1">
              <div class="mb-6 flex items-center justify-between">
                <div class="p-2 bg-carbon rounded-lg border border-wire group-hover:border-signal/30 transition-colors">
                  <Github class="text-signal" size={24} />
                </div>
                <span class={`font-mono text-xs uppercase px-2 py-1 rounded ${
                  tool.status === 'active' ? 'bg-cyan/20 text-cyan' :
                  tool.status === 'stable' ? 'bg-signal/20 text-signal' :
                  'bg-copper/20 text-copper'
                }`}>
                  {tool.status}
                </span>
              </div>
              <h2 class="font-headline text-2xl text-copper/90 tracking-wide mb-4 group-hover:text-copper transition-colors duration-200">
                {tool.name}
              </h2>
              <p class="font-body text-ash text-sm leading-relaxed mb-4">
                {tool.description}
              </p>
              <div class="flex flex-wrap gap-2">
                {tool.tags.map((tag) => (
                  <span class="font-mono text-xs text-ash/70 bg-carbon/50 px-2 py-1 rounded border border-wire/50">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div class="px-8 py-4 border-t border-wire/40 flex items-center group-hover:border-cyan/30 transition-colors duration-200">
              <span class="font-subhead uppercase text-sm text-ash/70 group-hover:text-cyan transition-colors duration-200">
                View Repository <span class="inline-block transform group-hover:translate-x-1 transition-transform duration-200">→</span>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-16 mb-12 border-t border-wire pt-12">
        <div class="mb-6">
          <h2 class="font-headline text-3xl text-chalk tracking-wide">
            CONTRIBUTE
          </h2>
        </div>
        <p class="font-body text-ash max-w-2xl leading-relaxed mb-6">
          All tools are released under open licenses. Contributions, forks, and derivative works are welcomed. Join the network of systems builders.
        </p>
        <a
          href="https://github.com/kybernetria"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-subhead uppercase text-sm text-signal border border-signal rounded-full px-6 py-2 hover:bg-signal hover:text-carbon transition-all duration-300 btn-hover"
        >
          <Github size={16} />
          Explore on GitHub
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
