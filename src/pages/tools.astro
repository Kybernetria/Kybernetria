---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Github, ExternalLink } from 'lucide-astro';
import { getCollection } from 'astro:content';

const base = '/';

const toolsEntries = await getCollection('tools');
const tools = toolsEntries
  .sort((a, b) => a.data.order - b.data.order)
  .map(entry => ({
    name: entry.data.name,
    description: entry.data.description,
    github: entry.data.github,
    tags: entry.data.tags,
    status: entry.data.status
  }));
---

<BaseLayout title="Tools | Kybernetria">
  <Navbar />

  <main class="pt-32 min-h-[80vh]">
    <div class="max-w-7xl mx-auto px-6 md:px-12 mb-16">
      <div class="mb-4">
        <h1 class="font-headline text-5xl md:text-7xl text-chalk leading-[0.9] tracking-wide">
          TOOLS
        </h1>
      </div>
      <p class="font-body text-ash text-lg max-w-2xl leading-relaxed">
        Open-source instruments for systems thinking, collective coordination, and the engineering of emancipatory architectures.
      </p>
    </div>

    <div class="max-w-7xl mx-auto px-6 md:px-12">
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {tools.map((tool) => (
          <article class="group relative bg-plate/50 border border-wire rounded-lg p-6 hover:border-signal/50 transition-all duration-300 hover:bg-plate/80">
            <div class="flex items-start justify-between mb-4">
              <h2 class="font-headline text-2xl text-chalk tracking-wide">
                {tool.name}
              </h2>
              <span class={`font-mono text-xs uppercase px-2 py-1 rounded ${
                tool.status === 'active' ? 'bg-cyan/20 text-cyan' :
                tool.status === 'stable' ? 'bg-signal/20 text-signal' :
                'bg-copper/20 text-copper'
              }`}>
                {tool.status}
              </span>
            </div>

            <p class="font-body text-ash text-sm leading-relaxed mb-6">
              {tool.description}
            </p>

            <div class="flex flex-wrap gap-2 mb-6">
              {tool.tags.map((tag) => (
                <span class="font-mono text-xs text-ash/70 bg-carbon/50 px-2 py-1 rounded border border-wire/50">
                  {tag}
                </span>
              ))}
            </div>

            <a
              href={tool.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-subhead uppercase text-sm text-chalk hover:text-signal transition-colors group/link"
            >
              <Github size={18} class="group-hover/link:text-signal transition-colors" />
              View Repository
              <ExternalLink size={14} class="opacity-50 group-hover/link:opacity-100 transition-opacity" />
            </a>
          </article>
        ))}
      </div>

      <div class="mt-16 mb-12 border-t border-wire pt-12">
        <div class="mb-6">
          <h2 class="font-headline text-3xl text-chalk tracking-wide">
            CONTRIBUTE
          </h2>
        </div>
        <p class="font-body text-ash max-w-2xl leading-relaxed mb-6">
          All tools are released under open licenses. Contributions, forks, and derivative works are welcomed. Join the network of systems builders.
        </p>
        <a
          href="https://github.com/kybernetria"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-subhead uppercase text-sm text-signal border border-signal rounded-full px-6 py-2 hover:bg-signal hover:text-carbon transition-all duration-300 btn-hover"
        >
          <Github size={16} />
          Explore on GitHub
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
