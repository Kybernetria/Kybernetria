---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Kybernetria" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="bg-carbon text-chalk antialiased selection:bg-signal selection:text-carbon w-full relative">
    <slot />
  </body>
</html>
