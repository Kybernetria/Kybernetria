---
import '../styles/global.css';
import '@fontsource/bebas-neue';
import '@fontsource/epilogue/700.css';
import '@fontsource/lora';
import '@fontsource/jetbrains-mono';

interface Props {
  title?: string;
}

const { title = "Kybernetria" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="bg-carbon text-chalk antialiased selection:bg-signal selection:text-carbon w-full relative pb-12">
    <slot />
  </body>
</html>
